# ─── LLM API Keys ───
# At least one is required
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=your-openai-api-key

# ─── Default LLM Configuration ───
DEFAULT_LLM_PROVIDER=anthropic
DEFAULT_LLM_MODEL=claude-sonnet-4-6

# ─── Binance ───
# Public endpoints (klines, ticker) work without keys
# Keys required for trading execution
BINANCE_API_KEY=
BINANCE_SECRET_KEY=

# ─── Database ───
DATABASE_URL=postgresql+asyncpg://syndicate:syndicate@localhost:5432/syndicate

# ─── Redis ───
REDIS_URL=redis://localhost:6379/0

# ─── WhatsApp (Twilio) ───
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=

# ─── Moltbook (AI Agent Social Network) ───
# Register at moltbook.com, verify via X/Twitter, get API key
MOLTBOOK_API_KEY=
MOLTBOOK_ENABLED=false

# ─── Platform Settings ───
PAPER_TRADING=true
LOG_LEVEL=INFO
